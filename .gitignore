__pycache__/

# TLS secrets — never commit (scrubbed from history 2026-06-22)
ssl/

# TTS-Audio-Output (ephemeral WAV-Dateien, kein Forschungsartefakt).
# Pro Assistant-Turn wird hier eine WAV geschrieben; sie werden NICHT
# committed. Im Gegensatz zu scratches/*/out/ (Forschungs-Artefakte) ist
# dies Session-Lifetime-Müll.
tts_outputs/

# Chat-Sessions (smoke-test / dev-Artefakte; 168 Files historisch in
# d7322c4 'wip tts' mit reingekommen — gehören nicht in den Repo-Stand).
# Laufzeit-Daten, lokal regenerierbar. Test-Fixtures liegen in
# tests/fixtures/ (committed) statt hier.
sessions/

# Debug-Logs: lokal pro Run (Server-Start, Smoke-Test, Stream-Bridge).
# Mehrere Versionen >50 MB historisch im Repo (Warn-Limit). Ab jetzt:
# nicht mehr committed.
local_debug.log
logs/local_debug.log
logs/*.log.local
