+import copy
+from typing import List, Dict, Any, Optional, Callable
+
+class InfiniteContextManager:
+    """
+    Manages the session history to prevent OOM errors during generation by enforcing
+    a sliding window, or eventually, a compressed memory manifold.
+    """
+    def __init__(self, max_history_messages: int = 10, max_tokens: Optional[int] = None):
+        self.max_history_messages = max_history_messages
+        self.max_tokens = max_tokens
+
+    def process_history(self, messages: List[Dict[str, Any]], tokenizer: Optional[Callable] = None) -> List[Dict[str, Any]]:
+        """
+        Processes the history to fit within constraints.
+        Returns a new list of messages safe for model generation.
+        """
+        if not messages:
+            return []
+
+        # Always preserve the system prompt if it exists (usually at index 0)
+        system_msgs = []
+        regular_msgs = []
+        
+        for msg in messages:
+            if msg.get("role") == "system":
+                system_msgs.append(msg)
+            else:
+                regular_msgs.append(msg)
+
+        # Token-based sliding window
+        if tokenizer is not None and self.max_tokens is not None:
+            current_msgs = regular_msgs.copy()
+            while len(current_msgs) > 1:
+                # Test how many tokens this combination uses
+                test_msgs = system_msgs + current_msgs
+                try:
+                    # Apply chat template (without generating prompt to just count past tokens)
+                    text = tokenizer.apply_chat_template(test_msgs, tokenize=False)
+                    tokens = tokenizer.encode(text)
+                    if len(tokens) <= self.max_tokens:
+                        break
+                except Exception:
+                    # If it fails, fallback to dropping
+                    pass
+                current_msgs.pop(0)
+
+            if len(current_msgs) < len(regular_msgs):
+                compression_notice = {
+                    "role": "system",
+                    "content": "[SYSTEM: Older context has been archived for memory efficiency. The following messages are the most recent interaction.]"
+                }
+                return system_msgs + [compression_notice] + current_msgs
+            return system_msgs + current_msgs
+
+        # Basic Sliding Window based on message count (Fallback)
+        if self.max_history_messages is not None and len(regular_msgs) > self.max_history_messages:
+            # We keep the most recent `self.max_history_messages` messages.
+            # To maintain conversational flow, we might want to ensure we don't split a user/assistant pair awkwardly,
+            # but taking the last N is generally fine.
+            truncated_msgs = regular_msgs[-self.max_history_messages:]
+            
+            # Future: Here we could inject a "compressed memory" message 
+            # representing the dropped messages.
+            compression_notice = {
+                "role": "system",
+                "content": "[SYSTEM: Older context has been archived for memory efficiency. The following messages are the most recent interaction.]"
+            }
+            
+            return system_msgs + [compression_notice] + truncated_msgs
+
+        # Token-based sliding window (if tokenizer and max_tokens provided)
+        if tokenizer is not None and self.max_tokens is not None:
+            # (To be implemented fully if we want strict token limits instead of message limits)
+            pass
+
+        return system_msgs + regular_msgs
+
