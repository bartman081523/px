+def _expand_kv_for_gqa(k, v, n_rep):
+    """Expand KV-Heads entlang Hq-Ratio (GQA-Standard-Pattern).
+    Idempotent für n_rep == 1. Genutzt in _chunked_attention, weil matmul
+    Hq/Hkv als Batch-Dims behandelt und nur bei 1 broadcastet.
+    Identisch zu F.scaled_dot_product_attention(enable_gqa=True) intern —
+    wir machen es explizit, weil unser chunked-Path kein SDPA nutzt.
+    Siehe scratches/4b-image/gqa_repeat.py + test_gqa_surgical.py für den
+    Pin-Test (4/4 grün, cos_sim >= 0.999999 vs SDPA-Referenz).
+    """
+    if n_rep == 1:
+        return k, v
+    return k.repeat_interleave(n_rep, dim=1), v.repeat_interleave(n_rep, dim=1)
